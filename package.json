{
  "name": "prosemirror-debate",
  "version": "0.0.0",
  "description": "ProseMirror-based editor that interoperates with Advanced Verbatim",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bench": "vitest bench --run",
    "typecheck": "tsc --noEmit",
    "round-trip": "tsx bin/round-trip.ts"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0",
    "jszip": "^3.10.1",
    "prosemirror-commands": "^1.6.2",
    "prosemirror-history": "^1.4.1",
    "prosemirror-keymap": "^1.2.2",
    "prosemirror-model": "^1.24.1",
    "prosemirror-state": "^1.4.3",
    "prosemirror-tables": "^1.8.5",
    "prosemirror-transform": "^1.10.2",
    "prosemirror-view": "^1.37.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
