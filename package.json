{
  "name": "cardmirror",
  "version": "0.1.0-beta.8",
  "description": "CardMirror — ProseMirror-based editor that interoperates with Advanced Verbatim",
  "license": "SEE LICENSE IN LICENSE",
  "author": "Anthony Trufanov",
  "homepage": "https://github.com/ant981228/cardmirror#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ant981228/cardmirror.git"
  },
  "bugs": {
    "url": "https://github.com/ant981228/cardmirror/issues"
  },
  "type": "module",
  "private": true,
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bench": "vitest bench --run",
    "typecheck": "tsc --noEmit",
    "round-trip": "tsx bin/round-trip.ts",
    "gen:new-template": "tsx scripts/gen-new-template.ts",
    "desktop:install": "npm --prefix apps/desktop install",
    "desktop:dev": "npm --prefix apps/desktop run dev",
    "desktop:build": "npm --prefix apps/desktop run build",
    "desktop:pack": "npm --prefix apps/desktop run pack",
    "desktop:dist": "npm --prefix apps/desktop run dist",
    "desktop:release": "npm --prefix apps/desktop run release",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "fast-xml-parser": "^4.5.0",
    "fflate": "^0.8.3",
    "loro-crdt": "1.13.6",
    "loro-prosemirror": "0.4.3",
    "nspell": "^2.1.5",
    "prosemirror-commands": "^1.6.2",
    "prosemirror-history": "^1.4.1",
    "prosemirror-keymap": "^1.2.2",
    "prosemirror-model": "^1.24.1",
    "prosemirror-state": "^1.4.3",
    "prosemirror-tables": "^1.8.5",
    "prosemirror-transform": "^1.10.2",
    "prosemirror-view": "^1.37.0",
    "tinyld": "^1.3.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "patch-package": "8.0.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^2.1.0"
  }
}
