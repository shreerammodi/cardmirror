# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# Node / future build artifacts (placeholders for when we have code)
node_modules/
dist/
build/
.next/
.turbo/
*.log
.env
.env.local

# Word lock files (when example docs are open in Word)
~$*.docx
~$*.dotm

# Local extracted-template scratch (we extract Debate.dotm to /tmp/, but
# guard against accidental in-repo extraction)
/_extracted/

# Vite build output
dist/
.vite/

# Reference docs (Verbatim upstream, example .docx files, Debate.dotm,
# custom macro exports). Kept locally for development reference but
# not part of the repo.
reference-docs/

# Compiled Electron main/preload output (apps/desktop/dist).
# Already covered by the root `dist/` rule above, but called out
# here since the desktop workspace builds into apps/desktop/dist.
apps/desktop/dist/

# Electron-builder artifacts (Phase 5).
release/

# `build/` is gitignored above as a generic build-output directory,
# but electron-builder's `buildResources` lives at
# apps/desktop/build/ and holds tracked source assets (icon.png).
# Re-include that specific path.
!apps/desktop/build/
!apps/desktop/build/**

# Local-only running notes / wishlist / scratchpad files. WISHLIST.md
# is the running queue of usability ideas and feedback to act on
# before the next release. WISHLIST.assets/ holds screenshots and
# other binary attachments referenced from the wishlist.
WISHLIST.md
WISHLIST.assets/
