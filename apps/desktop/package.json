{
  "name": "@cardmirror/desktop",
  "version": "0.1.0-alpha.1",
  "description": "CardMirror — Electron desktop wrapper",
  "author": "Anthony Trufanov",
  "homepage": "https://github.com/ant981228/cardmirror",
  "private": true,
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "build:main": "tsc -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "build:renderer": "npm --prefix ../.. run build -- --base=./",
    "start:web": "npm --prefix ../.. run dev",
    "start:electron": "wait-on http://localhost:5173 && electron .",
    "dev": "npm run build:main && concurrently --kill-others-on-fail --names \"vite,electron\" --prefix-colors \"cyan,magenta\" \"npm:start:web\" \"npm:start:electron\"",
    "pack": "npm run build:renderer && npm run build:main && electron-builder --dir",
    "dist": "npm run build:renderer && npm run build:main && electron-builder",
    "release": "npm run build:renderer && npm run build:main && electron-builder --publish always"
  },
  "build": {
    "appId": "com.cardmirror.app",
    "productName": "CardMirror",
    "executableName": "cardmirror",
    "electronVersion": "33.2.0",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../dist",
        "to": "renderer",
        "filter": ["**/*"]
      }
    ],
    "fileAssociations": [
      {
        "ext": "docx",
        "name": "Word Document",
        "description": "Microsoft Word document",
        "role": "Editor"
      },
      {
        "ext": "cmir",
        "name": "CardMirror Document",
        "description": "CardMirror native document",
        "role": "Editor"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ]
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "linux": {
      "category": "Office",
      "maintainer": "Anthony Trufanov <ant981228@gmail.com>",
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        {
          "target": "pacman",
          "arch": ["x64"]
        }
      ],
      "artifactName": "cardmirror-${version}.${ext}"
    },
    "pacman": {
      "depends": [
        "c-ares",
        "ffmpeg",
        "gtk3",
        "libevent",
        "libnotify",
        "libvpx",
        "libxslt",
        "libxss",
        "minizip",
        "nss",
        "re2",
        "snappy",
        "libxcrypt-compat"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "ant981228",
      "repo": "cardmirror"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1"
  }
}
